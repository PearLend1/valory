# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/valory

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OAuth Configuration
OAUTH_SERVER_URL=https://oauth.example.com
OWNER_OPEN_ID=owner-openid-123

# Application
VITE_APP_ID=valory-app-dev

# External API - Forge/LLM Integration
BUILT_IN_FORGE_API_URL=https://api.forge.example.com
BUILT_IN_FORGE_API_KEY=forge-api-key-placeholder

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=analytics-site-id
